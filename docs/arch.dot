digraph arch {
    graph [
        bgcolor="#0d1117"
        fontname="Courier New"
        fontcolor="#c9d1d9"
        pad="0.5"
        label="duel — Module Architecture"
        labelloc="t"
        fontsize=18
        rankdir=TB
    ]
    node [
        fontname="Courier New"
        fontsize=12
        style="filled,rounded"
        shape=box
    ]
    edge [
        fontname="Courier New"
        fontsize=10
        color="#58a6ff"
        fontcolor="#8b949e"
        arrowsize=0.8
    ]

    subgraph cluster_binary {
        label="duel binary"
        style="filled,rounded"
        color="#21262d"
        fillcolor="#161b22"
        fontcolor="#c9d1d9"
        fontsize=14

        main   [label="main.rs\n─────────────\ntokio main\nevent loop (40ms)\nterminal setup\npanic hook",    fillcolor="#1f4068" color="#58a6ff" fontcolor="#c9d1d9"]
        app    [label="app.rs\n─────────────\nApp state\nLoopState machine\nAppCommand enum\nspawn_actor/critic", fillcolor="#1f4068" color="#58a6ff" fontcolor="#c9d1d9"]
        ollama [label="ollama.rs\n─────────────\npre_warm()\nrun_actor()\nrun_critic()\ndo_stream() → chunk()", fillcolor="#0d3b2e" color="#3fb950" fontcolor="#c9d1d9"]
        ui     [label="ui.rs\n─────────────\ndraw(Frame, App)\ndraw_prompt()\ndraw_duel()\n5 themes + glow",    fillcolor="#3b1f4e" color="#bc8cff" fontcolor="#c9d1d9"]
        gpu    [label="gpu.rs\n─────────────\npoll_loop() 5s\nnvidia-smi CSV\nGpuInfo struct",               fillcolor="#4a2b0a" color="#d29922" fontcolor="#c9d1d9"]
        util   [label="util.rs\n─────────────\ntruncate()\ntruncate_display()\nUnicode-width safe",           fillcolor="#21262d" color="#6e7681" fontcolor="#c9d1d9"]
    }

    subgraph cluster_external {
        label="External Systems"
        style="filled,rounded"
        color="#21262d"
        fillcolor="#0d1117"
        fontcolor="#c9d1d9"
        fontsize=14

        ollama_api [label="Ollama API\nhttp://127.0.0.1:11434\n/api/generate (stream:true)\nqwen3.5:4b", shape=cylinder, fillcolor="#1a2a1a" color="#3fb950" fontcolor="#c9d1d9"]
        nvidia     [label="nvidia-smi\n--query-gpu CSV\nRTX 5080 + RTX 3080\n~26.5 GB VRAM",              shape=cylinder, fillcolor="#2a1a1a" color="#d29922" fontcolor="#c9d1d9"]
    }

    main   -> app    [label="creates App\nspawns gpu task"]
    main   -> gpu    [label="spawn poll_loop()"]
    main   -> ui     [label="terminal.draw()"]
    app    -> ollama [label="spawn_actor()\nspawn_critic()"]
    ollama -> app    [label="AppCommand\n(Token, TurnDone,\nModelReady)", style=dashed]
    gpu    -> app    [label="AppCommand\n(GpuStatus)", style=dashed]
    ui     -> util   [label="truncate()"]
    ui     -> app    [label="reads App state\n(read-only)"]
    ollama -> ollama_api [label="POST /api/generate\nstream ndjson"]
    gpu    -> nvidia     [label="subprocess\nnvidia-smi"]
}
