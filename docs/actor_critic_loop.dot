digraph actor_critic_loop {
    graph [
        bgcolor="#0d1117"
        fontname="Courier New"
        fontcolor="#c9d1d9"
        label="duel — Actor/Critic Refinement Sequence"
        labelloc="t"
        fontsize=18
        pad="0.6"
        rankdir=LR
        ranksep=2.2
        nodesep=0.3
        splines=ortho
    ]
    node [
        fontname="Courier New"
        fontsize=11
        style="filled,rounded"
        shape=box
        width=1.8
        height=0.5
    ]
    edge [
        fontname="Courier New"
        fontsize=9
        fontcolor="#8b949e"
        arrowsize=0.7
    ]

    // Swimlane headers
    hUser   [label="USER",          fillcolor="#1f4068" color="#58a6ff" fontcolor="#ffffff" height=0.6]
    hApp    [label="APP (app.rs)",  fillcolor="#0d3b2e" color="#3fb950" fontcolor="#ffffff" height=0.6]
    hOllama [label="OLLAMA\nqwen3.5:4b", fillcolor="#3b2a0a" color="#e3b341" fontcolor="#ffffff" height=0.6]

    { rank=same; hUser; hApp; hOllama }

    // Step nodes — User column
    u1 [label="Enter prompt\n\"write a sort\"",   fillcolor="#1a2e4a" color="#58a6ff" fontcolor="#c9d1d9"]
    u2 [label="Watch Actor\nstream tokens",        fillcolor="#1a2e4a" color="#58a6ff" fontcolor="#c9d1d9"]
    u3 [label="Watch Critic\nstream + score",      fillcolor="#1a2e4a" color="#58a6ff" fontcolor="#c9d1d9"]
    u4 [label="Watch Actor\nimprove (iter 2)",     fillcolor="#1a2e4a" color="#58a6ff" fontcolor="#c9d1d9"]
    u5 [label="Watch Critic\nre-score",            fillcolor="#1a2e4a" color="#58a6ff" fontcolor="#c9d1d9"]
    u6 [label="Space → pause\nor loop continues…", fillcolor="#1a2e4a" color="#58a6ff" fontcolor="#c9d1d9"]

    // Step nodes — App column
    a1 [label="start_loop()\nprewarm → spawn",     fillcolor="#0d2e1a" color="#3fb950" fontcolor="#c9d1d9"]
    a2 [label="actor_buf\n+= token (x N)",         fillcolor="#0d2e1a" color="#3fb950" fontcolor="#c9d1d9"]
    a3 [label="TurnDone{Actor}\nhist.push(Turn)",  fillcolor="#0d2e1a" color="#3fb950" fontcolor="#c9d1d9"]
    a4 [label="critic_buf\n+= token (x M)",        fillcolor="#0d2e1a" color="#3fb950" fontcolor="#c9d1d9"]
    a5 [label="TurnDone{Critic}\nextract_score()\niter += 1",         fillcolor="#0d2e1a" color="#3fb950" fontcolor="#c9d1d9"]
    a6 [label="actor_buf\n+= token (x N2)",        fillcolor="#0d2e1a" color="#3fb950" fontcolor="#c9d1d9"]
    a7 [label="TurnDone{Actor}\nhist.push(Turn)",  fillcolor="#0d2e1a" color="#3fb950" fontcolor="#c9d1d9"]
    a8 [label="critic_buf\n+= token (x M2)\nre-score",               fillcolor="#0d2e1a" color="#3fb950" fontcolor="#c9d1d9"]

    // Step nodes — Ollama column
    o1 [label="pre_warm()\n1 token ping",          fillcolor="#2e1a0a" color="#e3b341" fontcolor="#c9d1d9"]
    o2 [label="Actor iter 1\nPOST /api/generate\nsystem=ACTOR_SYS\ntemp=0.7 stream",    fillcolor="#2e1a0a" color="#e3b341" fontcolor="#c9d1d9"]
    o3 [label="Critic iter 1\nPOST /api/generate\nsystem=CRITIC_SYS\ntemp=0.4 stream",   fillcolor="#2e1a0a" color="#e3b341" fontcolor="#c9d1d9"]
    o4 [label="Actor iter 2\nprompt includes\nlast critic feedback\ntemp=0.7 stream",    fillcolor="#2e1a0a" color="#e3b341" fontcolor="#c9d1d9"]
    o5 [label="Critic iter 2\nPOST /api/generate\nScore: X/10\ntemp=0.4 stream",         fillcolor="#2e1a0a" color="#e3b341" fontcolor="#c9d1d9"]

    { rank=same; u1; a1; o1 }
    { rank=same; u2; a2; o2 }
    { rank=same; u3; a4; o3 }
    { rank=same; u4; a6; o4 }
    { rank=same; u5; a8; o5 }

    // Vertical flow
    u1 -> u2 -> u3 -> u4 -> u5 -> u6 [color="#58a6ff" style=invis]
    a1 -> a2 -> a3 -> a4 -> a5 -> a6 -> a7 -> a8 [color="#3fb950" style=invis]
    o1 -> o2 -> o3 -> o4 -> o5 [color="#e3b341" style=invis]

    // Cross-lane messages
    u1  -> a1  [label="Enter", color="#58a6ff"]
    a1  -> o1  [label="pre_warm()", color="#3fb950"]
    o1  -> a1  [label="ModelReady", color="#e3b341", style=dashed]
    a1  -> o2  [label="spawn_actor(1)", color="#3fb950"]
    o2  -> a2  [label="Token×N", color="#e3b341", style=dashed]
    a3  -> o3  [label="spawn_critic(1)", color="#3fb950"]
    o3  -> a4  [label="Token×M", color="#e3b341", style=dashed]
    a5  -> o4  [label="spawn_actor(2)\nwith critic feedback", color="#3fb950"]
    o4  -> a6  [label="Token×N2", color="#e3b341", style=dashed]
    a7  -> o5  [label="spawn_critic(2)", color="#3fb950"]
    o5  -> a8  [label="Token×M2\n+ Score:X/10", color="#e3b341", style=dashed]
}
